POSTGRES_USER=etl
POSTGRES_PASSWORD=etl
POSTGRES_DB=etl
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC_RAW=raw-docs

JWT_SECRET=please-change-me-in-production
JWT_EXPIRES_MIN=60

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

STORAGE_DIR=/data/files

EXTRACT_PORT=8001
API_PORT=8000
UI_PORT=5173

# GigaChat (Sber) — заполнить если нужно сравнение MLX-local vs cloud.
# Получить Authorization Key (Base64 of client_id:client_secret) на developers.sber.ru
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false
